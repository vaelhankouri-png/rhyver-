<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Maison RHYVÉR — Lighnd Collection 2026</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=Didact+Gothic&display=swap" rel="stylesheet" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --white: #ffffff;
      --off-white: #f7f6f3;
      --black: #0a0a0a;
      --light-gray: #e0e0e0;
      --mid-gray: #666666;
    }

    body {
      font-family: 'Didact Gothic', sans-serif;
      background: var(--white);
      color: var(--black);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── NAVIGATION ── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 48px;
      background: var(--white);
      border-bottom: 1px solid var(--light-gray);
      backdrop-filter: blur(10px);
      background-color: rgba(255, 255, 255, 0.95);
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--black);
    }

    .nav-links {
      display: flex;
      gap: 48px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--black);
      transition: opacity 0.3s;
    }

    .nav-links a:hover {
      opacity: 0.6;
    }

    .nav-cta {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: var(--black);
      color: var(--white);
      padding: 12px 32px;
      border: none;
      cursor: pointer;
      transition: all 0.3s;
      text-decoration: none;
      display: inline-block;
    }

    .nav-cta:hover {
      background: var(--white);
      color: var(--black);
      border: 1px solid var(--black);
    }

    /* ── HERO SECTION ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 120px 48px;
      padding-top: 180px;
      background: linear-gradient(135deg, var(--white) 0%, var(--off-white) 100%);
      overflow: hidden;
    }

    .hero-content {
      flex: 1;
      max-width: 600px;
      z-index: 10;
    }

    .hero-logo {
      font-family: 'Playfair Display', serif;
      font-size: 84px;
      font-weight: 900;
      letter-spacing: 8px;
      text-transform: uppercase;
      line-height: 1;
      margin-bottom: 40px;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
    }

    .hero-tagline {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 16px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--mid-gray);
      margin-bottom: 30px;
    }

    .hero-description {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 14px;
      line-height: 1.8;
      color: var(--mid-gray);
      margin-bottom: 50px;
      max-width: 500px;
    }

    .hero-cta {
      display: inline-block;
      font-family: 'Didact Gothic', sans-serif;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: var(--black);
      color: var(--white);
      padding: 16px 48px;
      border: 2px solid var(--black);
      text-decoration: none;
      transition: all 0.3s;
      cursor: pointer;
    }

    .hero-cta:hover {
      background: var(--white);
      color: var(--black);
    }

    .hero-image {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .hero-image img {
      max-width: 100%;
      height: auto;
      filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.15));
    }

    /* ── SECTION SHARED ── */
    section {
      padding: 100px 48px;
    }

    .section-label {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--mid-gray);
      margin-bottom: 14px;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 56px;
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1px;
      text-transform: uppercase;
      color: var(--black);
      margin-bottom: 24px;
    }

    .section-body {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 14px;
      color: var(--mid-gray);
      max-width: 580px;
      line-height: 1.8;
    }

    /* ── COLLECTION GRID ── */
    #collection {
      background: var(--black);
      color: var(--white);
    }

    #collection .section-label {
      color: #888;
    }

    #collection .section-title {
      color: var(--white);
    }

    #collection .section-body {
      color: #aaa;
    }

    .fragrance-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1px;
      margin-top: 50px;
    }

    .fragrance-card {
      background: #1a1a1a;
      padding: 40px;
      border: 1px solid #2a2a2a;
      transition: background 0.3s;
      cursor: pointer;
    }

    .fragrance-card:hover {
      background: #242424;
    }

    .card-name {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--white);
      margin-bottom: 12px;
      text-transform: uppercase;
    }

    .card-gender {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #666;
      margin-bottom: 20px;
    }

    .card-price {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 700;
      color: var(--white);
      margin-top: 20px;
    }

    .card-order {
      display: inline-block;
      margin-top: 20px;
      font-family: 'Didact Gothic', sans-serif;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--white);
      text-decoration: none;
      border-bottom: 1px solid #555;
      transition: border-color 0.3s;
    }

    .card-order:hover {
      border-bottom-color: var(--white);
    }

    /* ── FOOTER ── */
    footer {
      background: #050505;
      color: #555;
      padding: 60px 48px 30px;
      border-top: 1px solid #1a1a1a;
    }

    .footer-content {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 60px;
      margin-bottom: 40px;
    }

    .footer-brand h3 {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      color: var(--white);
      margin-bottom: 12px;
    }

    .footer-brand p {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 12px;
      line-height: 1.8;
      color: #666;
    }

    .footer-col-title {
      font-family: 'Didact Gothic', sans-serif;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #777;
      margin-bottom: 16px;
    }

    .footer-col a {
      display: block;
      font-family: 'Didact Gothic', sans-serif;
      font-size: 12px;
      color: #555;
      text-decoration: none;
      margin-bottom: 10px;
      transition: color 0.3s;
    }

    .footer-col a:hover {
      color: #999;
    }

    .footer-bottom {
      border-top: 1px solid #1a1a1a;
      padding-top: 30px;
      text-align: center;
      font-family: 'Didact Gothic', sans-serif;
      font-size: 11px;
      letter-spacing: 1px;
      color: #444;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      nav {
        padding: 16px 24px;
      }

      .nav-logo {
        font-size: 20px;
      }

      .nav-links {
        display: none;
      }

      .hero {
        flex-direction: column;
        padding: 100px 24px;
      }

      .hero-logo {
        font-size: 48px;
      }

      .section-title {
        font-size: 36px;
      }

      .footer-content {
        grid-template-columns: 1fr;
        gap: 30px;
      }
    }
  </style>
</head>
